<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/phwRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/morning_brief_widget_background"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/phwHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#DAD7E7"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textAllCaps="true" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/phwPlanetSymbol"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☿"
            android:textColor="#E1B9FF"
            android:textSize="28sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/phwPlanetName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/phwWindow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#C5BAE8"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/phwNext"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="#9EA4B8"
        android:textSize="11sp" />
</LinearLayout>
