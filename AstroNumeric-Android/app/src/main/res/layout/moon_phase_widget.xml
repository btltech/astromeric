<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mpwRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/morning_brief_widget_background"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/mpwEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌑"
            android:textSize="32sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/mpwPhaseName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/mpwPersonalDay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#E1B9FF"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/mpwGuidance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:ellipsize="end"
        android:maxLines="3"
        android:textColor="#DAD7E7"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/mpwUpdatedAt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#9EA4B8"
        android:textSize="10sp" />
</LinearLayout>
