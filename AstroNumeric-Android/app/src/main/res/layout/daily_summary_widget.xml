<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dswRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/morning_brief_widget_background"
    android:gravity="top"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/dswHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#DAD7E7"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/dswPersonalDay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#E1B9FF"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/dswMoonBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="#C5BAE8"
        android:textSize="10sp" />

    <TextView
        android:id="@+id/dswVibe"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/dswBulletOne"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="#E8E5F1"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/dswBulletTwo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="#D9DCE7"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/dswUpdatedAt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="#9EA4B8"
        android:textSize="10sp" />
</LinearLayout>
