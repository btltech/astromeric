<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
	<dict>
		<key>API_BASE_URL</key>
		<string>https://astromeric-backend-production.up.railway.app</string>
		<key>BGTaskSchedulerPermittedIdentifiers</key>
		<array>
			<string>com.astromeric.app.transitScan</string>
			<string>com.astromeric.app.cachePrewarm</string>
		</array>
		<key>CFBundleDevelopmentRegion</key>
		<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>AstroNumeric</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>AstroNumeric</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>NSHealthShareUsageDescription</key>
	<string>AstroNumeric reads health data (heart rate, sleep, steps) to correlate your biometrics with cosmic transits and provide personalized insights.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>We need your location to determine your birthplace timezone.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>AstroNumeric uses your microphone to record voice journal entries using live speech-to-text transcription.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>AstroNumeric transcribes your voice journal entries into text using on-device speech recognition.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
		<string>fetch</string>
	</array>
	<key>WEBSITE_BASE_URL</key>
	<string>https://astromeric.pages.dev</string>
</dict>
</plist>
